# ローカル開発用の環境変数テンプレート
# このファイルをコピーして .env.local を作成してください
# cp .env.example .env.local

# ─── デモモード ───────────────────────────────────────────
# true にするとSupabaseへの接続をスキップし、モックデータで動作します
# ログイン不要でアプリ全体を確認できます（ローカル開発推奨）
# 本番Vercelデプロイでは false にすること
NEXT_PUBLIC_DEMO_MODE=true

# ─── Supabase ────────────────────────────────────────────
# 本番・認証機能を使う場合は以下を設定してください
# https://supabase.com/dashboard → プロジェクト → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
